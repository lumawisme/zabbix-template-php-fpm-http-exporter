                    {
                        "uuid": "eaf22ed0c9d84c1b8d4b74b441f3504e",
                        "name": "PHP-FPM: Total Accepted Connections (Raw)",
                        "type": "DEPENDENT",
                        "key": "phpfpm.connections.total",
                        "history": "7d",
                        "description": "Tracks the total number of accepted connections handled by PHP-FPM since the service started. This raw counter is used mathematically by dependent triggers to detect pool restarts via counter resets. Source metric: phpfpm_accepted_connections_total.",
                        "preprocessing": [
                            {
                                "type": "PROMETHEUS_PATTERN",
                                "parameters": [
                                    "phpfpm_accepted_connections_total",
                                    "value",
                                    ""
                                ]
                            }
                        ],
                        "master_item": {
                            "key": "php_fpm.get_metrics"
                        },
                        "tags": [
                            {
                                "tag": "component",
                                "value": "php-fpm"
                            }
                        ],
                        "triggers": [
                            {
                                "uuid": "175153a63eb64c0f9f7d1efdb6144a8b",
                                "expression": "change(/PHP-FPM by HTTP Exporter/phpfpm.connections.total)<0",
                                "name": "PHP-FPM: Pool has been restarted",
                                "priority": "DISASTER",
                                "manual_close": "YES"
                            }
                        ]
                    },
                    {
                        "uuid": "aff185db98f84306b8ab752d6412e6b4",
